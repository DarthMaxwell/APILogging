{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": ""
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName"]
  },
  "ReverseProxy": {
    "Routes": {
      "register-route": {
        "ClusterId": "backend-cluster",
        "Match": {
          "Path": "/register",
          "Methods": ["POST"]
        }
      },
      "login-route": {
        "ClusterId": "backend-cluster",
        "Match": {
          "Path": "/login",
          "Methods": ["POST"]
        }
      },
      "checkauth-route": {
        "ClusterId": "backend-cluster",
        "Match": {
          "Path": "/checkauth",
          "Methods": ["Get"]
        }
      }
    },
    "Clusters": {
      "backend-cluster": {
        "Destinations": {
          "destination1": {
            "Address": ""
          }
        }
      }
    }
  }
}